Bootstrap: docker
From: maven:3.6.0-jdk-11-slim
Stage: build


%setup
    mkdir -p /argot/lib/
    mkdir -p /argot/src/
    mkdir -p /argot/libgraph/


%files
    ./src/* /argot/src/
    ./lib/* /argot/lib/
    ./libgraph/* /argot/libgraph/
    ./pom.xml /argot/

%environment
    export LC_ALL=C

%post
    cd /argot/
    mvn install:install-file -Dfile=/argot/lib/jgrapht-bundle-1.3.0.jar -DgroupId=org.jgrapht -DartifactId=jgrapht-bundle -Dversion=1.3.0 -Dpackaging=jar 
    mvn install:install-file -Dfile=/argot/lib/goUtility-4.0.jar -DgroupId=it.unipd.medicina.medcomp -DartifactId=goUtility -Dversion=4.0 -Dpackaging=jar 
    mvn install

%runscript
    java -jar /argot/target/Argot3-1.0.jar "$@"


%test
    java --version


%labels
    Authors Davide,Federico
    Version v1.0
    MyLabel Argot3


%help
    Container with Argot3.
    The installation is based on maven Docker.
